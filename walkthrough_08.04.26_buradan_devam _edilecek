        self.MAX_RISK_SCORE = st.max_risk_score
        self.MAX_TREND_SCORE = st.max_trend_score
        self.BONUS_CAP = st.bonus_cap
        self.FINAL_SCORE_MAX = st.final_score_max
        self.RISK_SCORE_ATR_MULT = st.risk_score_atr_mult
