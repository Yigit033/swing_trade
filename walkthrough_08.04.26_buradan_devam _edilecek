    MAX_RISK_SCORE = 15
    MAX_TREND_SCORE = 25          # NEW
    
    def __init__(self, config: Dict = None, settings: Optional["SmallCapSettings"] = None):
        """Initialize SmallCapScoring from SmallCapSettings.scoring_tuning."""
