logger = logging.getLogger(__name__)


class SmallCapSignals:
    """
    Signal triggers for Small Cap Momentum Engine.
    
    SENIOR TRADER TRIGGERS (3-Tier):
    
    TIER 1 - MANDATORY:
    - Volume surge >= 1.8x (was 1.5x)
