# ============================================================
# .env.example — Production Deployment Template
# ============================================================
# Copy: copy .env.example .env
# .env is in .gitignore — never commit secrets.
# ============================================================

# ──────────────────────────────────────
# DATABASE (Production)
# ──────────────────────────────────────
# PostgreSQL (Supabase / Fly Postgres / Railway)
# Yoksa SQLite kullanılır (local dev)
# DATABASE_URL=postgresql://postgres:PASSWORD@db.PROJECT.supabase.co:5432/postgres

# ──────────────────────────────────────
# LLM (Generative AI)
# ──────────────────────────────────────
# "openai" veya "gemini" — API key yoksa deterministik fallback
LLM_PROVIDER=openai

# OpenAI: https://platform.openai.com/api-keys
OPENAI_API_KEY=your_openai_api_key_here

# Gemini: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your_gemini_api_key_here

# ──────────────────────────────────────
# CORS (Production)
# ──────────────────────────────────────
# Frontend URL — virgülle ayır (örn: https://app.vercel.app,https://swing-trade.fly.dev)
# Boş bırakırsan allow_origins=["*"] kullanılır
# CORS_ORIGINS=https://your-frontend.vercel.app
